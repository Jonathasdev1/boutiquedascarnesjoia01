# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATE de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Porta HTTP do servidor (padrão: 3000)
PORT=3000

# Senha do painel administrativo (/admin)
# ⚠️  Obrigatório trocar antes de usar em produção!
ADMIN_PASSWORD=troque_essa_senha_aqui

# Origins autorizadas para CORS (separadas por virgula)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Intervalo de backup automatico do banco (em horas)
BACKUP_INTERVAL_HOURS=24
